RPC_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TRACKED_COINS=SOL,BTC,ETH,JUP,PYTH
TRACKED_WALLETS=
POLL_INTERVAL_SECONDS=30
MIN_SOL_ALERT=200
SOL_USD_PRICE=180
MAX_CONSECUTIVE_ERRORS=5
ERROR_BACKOFF_SECONDS=30
MAX_RESTARTS=10
RECAP_INTERVAL_HOURS=24
RECAP_NO_FETCH=1
RECAP_CHART=winrate_report.png
RECAP_TRACK_FILE=last_recap.txt
ERROR_NOTIFY_EVERY=3

# Partial-TP runner model: close PARTIAL_CLOSE_FRACTION at +PARTIAL_TP_R, move stop to BE,
# run remaining size to existing TP. No ATR trail after partial.
# Set FULL_TP_MODE=false and ENABLE_PARTIAL_TP=true to activate.
FULL_TP_MODE=false
ENABLE_PARTIAL_TP=true
PARTIAL_TP_R=1.0
PARTIAL_CLOSE_FRACTION=0.4
MOVE_STOP_TO_BREAKEVEN_AFTER_PARTIAL=true

# Portfolio slot replacement: when at max positions, replace weakest open position if
# incoming signal quality exceeds it by MIN_SCORE_DELTA. Partialed/near-TP/in-profit positions
# are protected. Replaced positions are NOT recorded as kill-switch outcomes.
ENABLE_POSITION_REPLACEMENT=true
POSITION_REPLACEMENT_MIN_SCORE_DELTA=0.12
POSITION_REPLACEMENT_PROTECT_PARTIALED=true
POSITION_REPLACEMENT_PROTECT_NEAR_TP_R=0.8
POSITION_REPLACEMENT_PROTECT_IN_PROFIT_R=0.5
POSITION_REPLACEMENT_PREFERRED_BONUS=0.05

# Reject-memory: master enable/disable (0=off). Per-family TTLs override the specific window.
REJECT_MEMORY_TTL_SEC=300
REJECT_MEMORY_TTL_STALE_OR_DRIFT=120
REJECT_MEMORY_TTL_SESSION_BLOCKED=300
REJECT_MEMORY_TTL_MARGIN=300

# Dead-zone soft override: allow high-score aligned setups through despite dead_zone session.
# Uses total_score (not raw confidence). Lower threshold = more permissive.
DEAD_ZONE_OVERRIDE_MIN_SCORE=0.84

# Market regime detection/gating
BLOCK_CONTINUATION_IN_CHOP=true
BLOCK_REVERSAL_AGAINST_DUAL_TREND=true
WEAK_TREND_SIZE_MULT=0.70
MARKET_REGIME_LOOKBACK=30
MARKET_REGIME_ATR_EXPANSION_RATIO=1.08
MARKET_REGIME_ATR_CONTRACTION_RATIO=0.94
MARKET_REGIME_EMA_SPREAD_STRONG_PCT=0.0025
MARKET_REGIME_BREAKOUT_ATR=0.20
MARKET_REGIME_RANGE_MID_PCT=0.20
MARKET_REGIME_STRONG_SCORE=4
MARKET_REGIME_CHOP_SCORE=1

# Protection order recovery
AUTO_REPLACE_MISSING_PROTECTION_ON_BOOT=true

# Exit reject/backoff hardening
LIVE_EXIT_UNKNOWN_MAX_RETRIES=4
LIVE_EXIT_UNKNOWN_BACKOFF_SEC=20
LIVE_EXIT_UNKNOWN_ESCALATE_EVERY=3
LIVE_MONITOR_ORPHAN_TP_GRACE_SEC=45

# Continuation hardening
CONT_REGIME_STRONG_BONUS=0.08
CONT_REGIME_CHOP_PENALTY=-0.14
CONT_REGIME_UNKNOWN_PENALTY=-0.03
CONT_LATE_ENTRY_PENALTY_ATR=1.20
CONT_LATE_ENTRY_HARD_BLOCK_ATR=2.20
CONT_LATE_ENTRY_HARD_BLOCK_RANGE_ATR=2.60
CONT_LATE_ENTRY_PENALTY_SCORE=-0.08
CONT_PULLBACK_TIGHT_MAX_ATR=0.80
CONT_PULLBACK_EXTENDED_ATR=1.40
CONT_PULLBACK_REWARD=0.05
CONT_PULLBACK_PENALTY=-0.07
CONT_DIRECTIONAL_LOSS_PENALTY=-0.12

# Stale-entry filter: reject entry if price has moved more than SIGNAL_STALE_ATR_MULT ATR
# from the signal's entry_price. Replaces the old hardcoded MAX_SIGNAL_TO_ENTRY_ATR=1.2.
# Backward-compat: if SIGNAL_STALE_ATR_MULT is unset, falls back to MAX_SIGNAL_TO_ENTRY_ATR,
# then to 3.0. SIGNAL_MOMENTUM_REENTRY_ATR (default 0 = disabled): if > 0, allow re-entry
# when price has pulled back within this many ATR of entry after a stale rejection.
SIGNAL_STALE_ATR_MULT=3.0
SIGNAL_MOMENTUM_REENTRY_ATR=0.0

# Session blocking — swing override: when true, swing-timeframe signals (1h/4h or
# setup_family=swing) bypass the session soft-block without needing to meet
# SESSION_OVERRIDE_MIN_SCORE. Hard blocks (BLOCKED_SESSIONS / per-bucket) still apply.
SWING_SESSION_OVERRIDE=false
